<Window x:Class="WPF_FitnessClub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_FitnessClub"
        mc:Ignorable="d"
        MinWidth="600px"
        MinHeight="520px"
        Title="{DynamicResource MainWindowTitle}" 
        Height="450" 
        Width="800" 
        WindowState="Maximized"
        Style="{StaticResource WindowStyle}">

    <Window.InputBindings>
        <KeyBinding Key="L" Modifiers="Control" Command="{Binding LogoutCommand}"/>
    </Window.InputBindings>
    
    <Grid Style="{StaticResource ResponsiveGridStyle}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--#region Меню-->
        <Border Grid.Column="0" Style="{StaticResource CustomBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Верхние кнопки -->
                <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,10,0,0">
                    <Button Style="{StaticResource CircleButtonStyle}" Click="HomeButton_Click">
                        <Path Data="{StaticResource HomeIcon}" Fill="White" Stretch="Uniform" Width="20" Height="20"/>
                    </Button>

                    <Button x:Name="AddSubscriptionButon" 
                            Content="✚" 
                            Style="{StaticResource CircleButtonStyle}" 
                            Margin="3,3,3,3"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="White"
                            Visibility="{Binding AddSubscriptionVisible}"
                            ToolTip="Добавить абонемент"
                            Click="AddSubscriptionButton_Click" />

                    <Button Style="{StaticResource CircleButtonStyle}" Click="DataTableButton_Click" 
        Visibility="{Binding AdminRoleVisible}">
                        <Path Data="{StaticResource AdminIcon}" Fill="White" Stretch="Uniform" Width="20" Height="20"/>
                    </Button>

                    <Button x:Name="CoachClientsButton" 
                            Content="👥" 
                            Style="{StaticResource CircleButtonStyle}" 
                            Margin="3,3,3,3"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="White"
                            ToolTip="Мои клиенты"
                            Visibility="{Binding CoachRoleVisible}"
                            Click="CoachClientsButton_Click" />
                </StackPanel>
                
                <!-- Нижняя панель кнопок -->
                <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,0,0,10">

                    <Button Style="{StaticResource CircleButtonStyle}" Click="LogoutButton_Click">
                        <Path Data="{StaticResource LogoutIcon}" Stroke="White" StrokeThickness="2" 
          Stretch="Uniform" Width="20" Height="20" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>


                    <Button x:Name="PersonalAccountButton" 
        Style="{StaticResource CircleButtonStyle}" 
        Click="PersonalAccountButon_Click"
        Margin="0,0,0,15">
                        <!-- Рисуем нашу новую иконку -->
                        <Path Data="{StaticResource UserIcon}" 
          Fill="White" 
          Stretch="Uniform" 
          Width="22" Height="22" 
          Stroke="White" 
          StrokeThickness="0.5"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <!--#endregion-->
            
        <!--#region Основная область содержимого-->
        <Grid Grid.Column="1">
            <ContentControl x:Name="MainContent"/>
        </Grid>
        <!--#endregion-->
    </Grid>
</Window>
