<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:WPF_FitnessClub">

    <!-- Стиль для RadioButton (Переключатели) -->
    <Style x:Key="CustomRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="Margin" Value="8,0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Внешний круг -->
                        <Ellipse x:Name="RadioOuter"
                                 Width="20" Height="20"
                                 Stroke="{DynamicResource PrimaryRedBrush}"
                                 StrokeThickness="2"
                                 Fill="{DynamicResource BackgroundBrush}"/>

                        <!-- Внутренний кружок (точка выбора) -->
                        <Ellipse x:Name="RadioInner"
                                 Width="10" Height="10"
                                 Fill="{DynamicResource PrimaryRedBrush}"
                                 Opacity="0"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>

                        <ContentPresenter Grid.Column="1"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Когда выбрано -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="RadioInner" Property="Opacity" Value="1"/>
                            <Setter TargetName="RadioOuter" Property="StrokeThickness" Value="2.5"/>
                        </Trigger>
                        <!-- При наведении -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RadioOuter" Property="Stroke" Value="{DynamicResource DarkRedBrush}"/>
                            <Setter TargetName="RadioInner" Property="Fill" Value="{DynamicResource DarkRedBrush}"/>
                        </Trigger>
                        <!-- Когда кнопка отключена -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="RadioOuter" Property="Stroke" Value="{DynamicResource LightGrayBrush}"/>
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>