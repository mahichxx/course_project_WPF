<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Минималистичная тень -->
    <DropShadowEffect x:Key="CardShadow" BlurRadius="4" ShadowDepth="1" Direction="270" Color="Black" Opacity="0.1"/>

    <!-- Стиль для прокрутки (Scroll), который вызывал ошибку -->
    <Style x:Key="ResponsiveScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <!-- Стиль для сетки (Grid) -->
    <Style x:Key="ResponsiveGridStyle" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
    </Style>

    <!-- Стиль для рамок (Карточек) -->
    <Style x:Key="CustomBorderStyle" TargetType="Border">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LightGrayBrush}"/>
        <Setter Property="CornerRadius" Value="0"/>
        <!-- ОСТРЫЕ УГЛЫ -->
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
    </Style>

    <!-- Стиль для содержимого вкладок -->
    <Style x:Key="TabContentStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,20,0,0"/>
    </Style>

</ResourceDictionary>