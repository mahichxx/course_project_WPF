<Window x:Class="WPF_FitnessClub.View.RegistrationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_FitnessClub"
        xmlns:windows="clr-namespace:WPF_FitnessClub.View" 
        xmlns:viewmodels="clr-namespace:WPF_FitnessClub.ViewModels"
        mc:Ignorable="d"
        Title="{DynamicResource RegistrationTitle}"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Кнопки смены языка -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="3"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,15,15,0">

            <!-- Кнопка RU -->
            <Button x:Name="RussianButton" Click="RussianButton_Click" Content="RU" Width="45" Height="30" Margin="5,0" Foreground="Black">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="2" CornerRadius="8" BorderBrush="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryRedBrush}"/>
                                            <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                        <Trigger Property="Tag" Value="Active">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryRedBrush}"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                                            <Setter TargetName="border" Property="Opacity" Value="1.0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Кнопка EN -->
            <Button x:Name="EnglishButton" Click="EnglishButton_Click" Content="EN" Width="45" Height="30" Foreground="Black">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="2" CornerRadius="8" BorderBrush="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryRedBrush}"/>
                                            <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                        <Trigger Property="Tag" Value="Active">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryRedBrush}"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                                            <Setter TargetName="border" Property="Opacity" Value="1.0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- ГЛАВНЫЙ ОРАНЖЕВЫЙ/ЗЕЛЕНЫЙ БОКС -->
        <Border x:Name="MainBorder"
                Grid.Row="1" Grid.Column="1"
                BorderThickness="0"
                CornerRadius="25" 
                Width="380"
                Height="Auto"
                MinHeight="500"      
                Padding="0,25,0,20"
                ClipToBounds="True"  
                VerticalAlignment="Center"
                Background="{DynamicResource PrimaryRedBrush}"
                HorizontalAlignment="Center"
                Effect="{StaticResource CardShadow}">

            <TabControl x:Name="MainTabControl" 
                        Style="{StaticResource CustomTabControlStyle}" 
                        SelectionChanged="MainTabControl_SelectionChanged" >

                <!-- авт -->
                <TabItem Header="{DynamicResource LoginTitle}"
                         Style="{StaticResource AuthTabItemStyle}">
                    <StackPanel Margin="30,45,30,30" HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource Login}" Style="{StaticResource AuthTextBlockStyle}" Margin="0,0,0,5"/>
                        <TextBox x:Name="LoginInput"
                                 Width="220" 
                                 Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AuthTextBoxStyle}" />

                        <TextBlock Text="{DynamicResource Password}" Style="{StaticResource AuthTextBlockStyle}" Margin="0,15,0,5"/>
                        <PasswordBox x:Name="PasswordInput"
                                     Width="220"
                                     Style="{StaticResource AuthPasswordBoxStyle}"
                                     PreviewKeyDown="PasswordBox_PreviewKeyDown" />

                        <Button x:Name="EnterButton"
                                Content="{DynamicResource LoginButton}"  
                                IsDefault="True"
                                MinWidth="130" 
                                Margin="0,50,0,0" 
                                Style="{DynamicResource EnterButton}"
                                Command="{Binding EnterCommand}"
                                CommandParameter="{Binding ElementName=PasswordInput}"/>
                    </StackPanel>
                </TabItem>

                <!-- гестис -->
                <TabItem Header="{DynamicResource RegistrationTitle}"
         Style="{StaticResource AuthTabItemStyle}">
                    <StackPanel Margin="30,15,30,15" HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource FullName}" Style="{StaticResource AuthTextBlockStyle}" Margin="0,2,0,2"/>
                        <TextBox x:Name="FullNameInput" Width="220" 
                 Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource AuthTextBoxStyle}" Margin="0,0,0,8"/>

                        <TextBlock Text="{DynamicResource Email}" Style="{StaticResource AuthTextBlockStyle}" Margin="0,2,0,2"/>
                        <TextBox x:Name="EmailInput" Width="220" 
                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource AuthTextBoxStyle}" Margin="0,0,0,8"/>

                        <TextBlock Text="{DynamicResource Login}" Style="{StaticResource AuthTextBlockStyle}" Margin="0,2,0,2"/>
                        <TextBox x:Name="RegLoginInput" Width="220" 
                 Text="{Binding RegLogin, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource AuthTextBoxStyle}" Margin="0,0,0,8"/>

                        <TextBlock Text="{DynamicResource Password}" Style="{StaticResource AuthTextBlockStyle}" Margin="0,2,0,2"/>
                        <PasswordBox x:Name="RegPasswordInput" Width="220" 
                     Style="{StaticResource AuthPasswordBoxStyle}"
                     PreviewKeyDown="PasswordBox_PreviewKeyDown" Margin="0,0,0,8"/>

                        <TextBlock Text="{DynamicResource ConfirmPassword}" Style="{StaticResource AuthTextBlockStyle}" Margin="0,2,0,2"/>
                        <PasswordBox x:Name="ConfirmPasswordInput" Width="220" 
                     Style="{StaticResource AuthPasswordBoxStyle}"
                     Tag="{Binding ElementName=RegPasswordInput}"
                     PreviewKeyDown="PasswordBox_PreviewKeyDown" Margin="0,0,0,8"/>

                        <Button x:Name="RegisterButton"
                Content="{DynamicResource RegisterButton}"
                MinWidth="160"
                Margin="0,20,0,0"
                Style="{DynamicResource EnterButton}" 
                Command="{Binding RegisterCommand}"
                CommandParameter="{Binding ElementName=ConfirmPasswordInput}" />
                    </StackPanel>
                </TabItem>

            </TabControl>
        </Border>
    </Grid>
</Window>