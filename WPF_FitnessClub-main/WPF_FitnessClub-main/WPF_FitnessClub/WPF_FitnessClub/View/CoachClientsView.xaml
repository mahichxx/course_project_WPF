<Window x:Class="WPF_FitnessClub.View.CoachClientsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:WPF_FitnessClub.View"
        xmlns:converters="clr-namespace:WPF_FitnessClub.Converters"
        mc:Ignorable="d" 
        Title="{DynamicResource CoachClientsTitle}" 
        Height="650" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Style="{StaticResource WindowStyle}">

    <Window.Resources>
        <!-- 1. ШАБЛОН ДЛЯ МОИХ КЛИЕНТОВ (с кнопками Подробнее и Удалить) -->
        <DataTemplate x:Key="ClientItemTemplate">
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                BorderBrush="{DynamicResource LightGrayBrush}" 
                BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,10" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Ellipse Width="45" Height="45" Fill="{DynamicResource BackgroundBrush}"/>
                        <Path Data="{StaticResource UserIcon}" Fill="{DynamicResource PrimaryRedBrush}" 
                          Stretch="Uniform" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                        <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="{Binding Email}" FontSize="12" Opacity="0.6" Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="{DynamicResource DetailsButton}" Style="{StaticResource DefaultButtonStyle}" 
                            Width="110" Height="32" Margin="0,0,10,0" Click="ShowClientPlansButton_Click" CommandParameter="{Binding}"/>
                        <Button Content="{DynamicResource RemoveButton}" Style="{StaticResource DefaultButtonStyle}" 
                            Background="#FF4C4C" Width="100" Height="32" Click="RemoveClientButton_Click" CommandParameter="{Binding}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- 2. ШАБЛОН ДЛЯ ДОСТУПНЫХ КЛИЕНТОВ (ТОЛЬКО КНОПКА ДОБАВИТЬ) -->
        <DataTemplate x:Key="AvailableClientItemTemplate">
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                BorderBrush="{DynamicResource LightGrayBrush}" 
                BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,10" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Ellipse Width="45" Height="45" Fill="{DynamicResource BackgroundBrush}"/>
                        <Path Data="{StaticResource UserIcon}" Fill="{DynamicResource PrimaryRedBrush}" 
                          Stretch="Uniform" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                        <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="{Binding Email}" FontSize="12" Opacity="0.6" Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>

                    <!-- Тут только одна кнопка -->
                    <Button Grid.Column="2" Content="{DynamicResource AddButton}" 
                        Style="{StaticResource DefaultButtonStyle}" 
                        Width="120" Height="32"
                        Click="AddClientButton_Click" CommandParameter="{Binding}"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка (без синего фона!) -->
        <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" Padding="20,15">
            <Grid>
                <StackPanel>
                    <TextBlock Text="{DynamicResource ClientManagement}" Style="{StaticResource HeaderTextBlockStyle}" Margin="0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="{DynamicResource Coach}" Opacity="0.6"/>
                        <TextBlock Text="{Binding CurrentCoach.FullName}" FontWeight="Bold" Margin="5,0"/>
                    </StackPanel>
                </StackPanel>

                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Content="{DynamicResource RefreshButton}" 
                        Style="{StaticResource DefaultButtonStyle}" 
                        Width="110" Height="30" Click="RefreshButton_Click"/>
            </Grid>
        </Border>

        <!-- Вкладки (Центрированные и стильные) -->
        <TabControl Grid.Row="1" Margin="10" Style="{StaticResource CustomTabControlStyle}">

            <!-- Вкладка: Мои клиенты -->
            <TabItem Header="{DynamicResource MyClients}" Style="{StaticResource CustomTabItemStyle}">
                <ListBox ItemsSource="{Binding Clients}" 
                 ItemTemplate="{StaticResource ClientItemTemplate}" 
                 Background="Transparent" BorderThickness="0"
                 HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </TabItem>

            <!-- Вкладка: Доступные клиенты -->
            <TabItem Header="{DynamicResource AllClients}" Style="{StaticResource CustomTabItemStyle}">
                <!-- ИСПОЛЬЗУЕМ AvailableClientItemTemplate -->
                <ListBox ItemsSource="{Binding AvailableClients}" 
                 ItemTemplate="{StaticResource AvailableClientItemTemplate}"
                 Background="Transparent" BorderThickness="0"
                 HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </TabItem>
        </TabControl>
    </Grid>
</Window>