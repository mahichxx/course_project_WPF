<UserControl x:Class="WPF_FitnessClub.View.PersonalAccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_FitnessClub.View"
             xmlns:converters="clr-namespace:WPF_FitnessClub.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="1200">

    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="Esc" Command="{Binding CancelCommand}"/>
    </UserControl.InputBindings>

    <UserControl.Resources>
        <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converters:NonZeroToVisibilityConverter x:Key="NonZeroToVisibilityConverter"/>

        <!-- Шаблоны планов -->
        <DataTemplate x:Key="WorkoutPlanTemplate">
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" Margin="0,5" Padding="10" CornerRadius="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" />
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12" Opacity="0.7" Foreground="{DynamicResource TextBrush}" />
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="{Binding IsCompleted, Mode=TwoWay}" Command="{Binding DataContext.MarkWorkoutPlanCompletedCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="NutritionPlanTemplate">
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" Margin="0,5" Padding="10" CornerRadius="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" />
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12" Opacity="0.7" Foreground="{DynamicResource TextBrush}" />
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="{Binding IsCompleted, Mode=TwoWay}" Command="{Binding DataContext.MarkNutritionPlanCompletedCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <!-- ОДИН ГЛАВНЫЙ СКРОЛЛЕР НА ВСЁ ОКНО -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,0,50">

                <TextBlock Text="{DynamicResource PersonalAccountTitle}" 
                           Style="{StaticResource HeaderTextBlockStyle}" 
                           Margin="20,40,20,20" HorizontalAlignment="Center"/>

                <!-- TabControl теперь растянут, центрируем содержимое внутри вкладок -->
                <TabControl SelectedIndex="{Binding SelectedTabIndex}" 
                            Style="{StaticResource CustomTabControlStyle}"
                            HorizontalAlignment="Stretch">

                    <!-- Вкладка 1: Личная информация -->
                    <TabItem Header="{DynamicResource PersonalInfoTab}" Style="{StaticResource CustomTabItemStyle}">
                        <StackPanel Width="450" HorizontalAlignment="Center" Margin="0,30,0,30">
                            <TextBlock Text="{DynamicResource FullName}" Style="{StaticResource CustomTextBlockStyle}"/>
                            <TextBox Text="{Binding FullName}" IsEnabled="{Binding IsEditMode}" Style="{StaticResource CustomTextBoxStyle}"/>

                            <TextBlock Text="Телефон (+375 (XX) XXX-XX-XX)" Style="{StaticResource CustomTextBlockStyle}" Margin="0,15,0,0"/>
                            <TextBox Text="{Binding Phone}" IsEnabled="{Binding IsEditMode}" Style="{StaticResource CustomTextBoxStyle}"/>

                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Возраст" Style="{StaticResource CustomTextBlockStyle}"/>
                                    <TextBox Text="{Binding Age}" PreviewTextInput="NumberValidationTextBox"  IsEnabled="{Binding IsEditMode}" Style="{StaticResource CustomTextBoxStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Пол" Style="{StaticResource CustomTextBlockStyle}"/>
                                    <ComboBox SelectedIndex="{Binding GenderIndex}" IsEnabled="{Binding IsEditMode}" Style="{StaticResource CustomComboBoxStyle}">
                                        <ComboBoxItem Content="Мужской"/>
                                        <ComboBoxItem Content="Женский"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <StackPanel Visibility="{Binding IsClientRole, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid Margin="0,15,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Вес (кг)" Style="{StaticResource CustomTextBlockStyle}"/>
                                        <TextBox Text="{Binding Weight}" PreviewTextInput="NumberValidationTextBox"  IsEnabled="{Binding IsEditMode}" Style="{StaticResource CustomTextBoxStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Рост (см)" Style="{StaticResource CustomTextBlockStyle}"/>
                                        <TextBox Text="{Binding Height}" PreviewTextInput="NumberValidationTextBox"  IsEnabled="{Binding IsEditMode}" Style="{StaticResource CustomTextBoxStyle}"/>
                                    </StackPanel>
                                </Grid>
                                <Border Background="#FFF3F3F3" CornerRadius="10" Margin="0,30,0,0" Padding="20" Effect="{StaticResource CardShadow}">
                                    <StackPanel>
                                        <TextBlock Text="Ваша норма калорий:" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Black"/>
                                        <TextBlock Text="{Binding DailyCalories}" FontSize="26" Foreground="#E11A22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                                <Button Content="{DynamicResource EditButton}" Command="{Binding EditCommand}" Visibility="{Binding ViewModeVisible}" Style="{StaticResource DefaultButtonStyle}" Margin="0,0,10,0" Width="120"/>
                                <Button Content="{DynamicResource SaveButton}" Command="{Binding SaveCommand}" Visibility="{Binding EditModeVisible}" Style="{StaticResource DefaultButtonStyle}" Margin="0,0,10,0" Width="100"/>
                                <Button Content="{DynamicResource CancelButton}" Command="{Binding CancelCommand}" Visibility="{Binding EditModeVisible}" Style="{StaticResource DefaultButtonStyle}" Width="100"/>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <!-- Вкладка 2: Настройки -->
                    <TabItem Header="{DynamicResource AppSettingsTab}" Style="{StaticResource CustomTabItemStyle}">
                        <StackPanel Width="450" HorizontalAlignment="Center" Margin="0,30,0,30">
                            <TextBlock Text="{DynamicResource LanguageSelection}" Style="{StaticResource CustomTextBlockStyle}" HorizontalAlignment="Center"/>
                            <ComboBox x:Name="LanguageSelectionComboBox" SelectionChanged="LanguageSelectionComboBox_SelectionChanged" Style="{StaticResource CustomComboBoxStyle}" Margin="0,5,0,25">
                                <ComboBoxItem Content="{DynamicResource RussianLanguage}" Tag="ru-RU" />
                                <ComboBoxItem Content="{DynamicResource EnglishLanguage}" Tag="en-US" />
                            </ComboBox>
                            <TextBlock Text="{DynamicResource ThemeSelection}" Style="{StaticResource CustomTextBlockStyle}" HorizontalAlignment="Center"/>
                            <ComboBox x:Name="ThemeSelectionComboBox" SelectionChanged="ThemeSelectionComboBox_SelectionChanged" Style="{StaticResource CustomComboBoxStyle}">
                                <ComboBoxItem Content="{DynamicResource LightTheme}" Tag="Light" />
                                <ComboBoxItem Content="{DynamicResource DarkTheme}" Tag="Dark" />
                            </ComboBox>
                        </StackPanel>
                    </TabItem>

                    <!-- Вкладка 3: Безопасность -->
                    <TabItem Header="{DynamicResource SecurityTab}" Style="{StaticResource CustomTabItemStyle}">
                        <StackPanel Width="450" HorizontalAlignment="Center" Margin="0,30,0,30">
                            <TextBlock Text="{DynamicResource ChangePasswordTitle}" Style="{StaticResource HeaderTextBlockStyle}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <TextBlock Text="{DynamicResource Password}" Style="{StaticResource CustomTextBlockStyle}"/>
                            <TextBox x:Name="SecurityCurrentPasswordInput" Style="{StaticResource CustomTextBoxStyle}" Text="{Binding Password}" IsReadOnly="true" Margin="0,5,0,15"/>
                            <TextBlock Text="{DynamicResource NewPassword}" Style="{StaticResource CustomTextBlockStyle}"/>
                            <PasswordBox x:Name="SecurityNewPasswordInput" Style="{StaticResource CustomPasswordBoxStyle}" PreviewKeyDown="PasswordBox_PreviewKeyDown"/>
                            <TextBlock Text="{DynamicResource ConfirmPassword}" Style="{StaticResource CustomTextBlockStyle}" Margin="0,15,0,5"/>
                            <PasswordBox x:Name="SecurityConfirmPasswordInput" Style="{StaticResource CustomPasswordBoxStyle}" PreviewKeyDown="PasswordBox_PreviewKeyDown"/>
                            <Button Content="{DynamicResource ChangePasswordButton}" Command="{Binding ChangePasswordCommand}" Style="{StaticResource DefaultButtonStyle}" Margin="0,30,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </TabItem>

                    <!-- Вкладки Планов -->
                    <TabItem Header="{DynamicResource WorkoutPlansTab}" Visibility="{Binding IsClientRole, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{StaticResource CustomTabItemStyle}">
                        <StackPanel MaxWidth="800" HorizontalAlignment="Center" Margin="0,30,0,30">
                            <TextBlock Text="{DynamicResource YourWorkoutPlans}" Style="{StaticResource HeaderTextBlockStyle}" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                            <ListBox ItemsSource="{Binding WorkoutPlans}" ItemTemplate="{StaticResource WorkoutPlanTemplate}" Style="{StaticResource CustomListBoxStyle}" Background="Transparent" BorderThickness="0"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="{DynamicResource NutritionPlansTab}" Visibility="{Binding IsClientRole, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{StaticResource CustomTabItemStyle}">
                        <StackPanel MaxWidth="800" HorizontalAlignment="Center" Margin="0,30,0,30">
                            <TextBlock Text="{DynamicResource YourNutritionPlans}" Style="{StaticResource HeaderTextBlockStyle}" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                            <ListBox ItemsSource="{Binding NutritionPlans}" ItemTemplate="{StaticResource NutritionPlanTemplate}" Style="{StaticResource CustomListBoxStyle}" Background="Transparent" BorderThickness="0"/>
                        </StackPanel>
                    </TabItem>

                    <!-- Вкладка 6: Мои занятия (АДАПТИВНАЯ И ЛИСТАЕТСЯ) -->
                    <TabItem Header="{DynamicResource MySubscriptionsTab}" Style="{StaticResource CustomTabItemStyle}" Visibility="{Binding IsClientRole, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel MaxWidth="1200" HorizontalAlignment="Center" Margin="0,30,0,30">
                            <TextBlock Text="Ваши текущие записи" Style="{StaticResource HeaderTextBlockStyle}" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                            <ItemsControl ItemsSource="{Binding UserSubscriptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="270" Height="240" Margin="10" CornerRadius="12" 
                                                Background="{DynamicResource SecondaryBackgroundBrush}" Effect="{StaticResource CardShadow}">
                                            <StackPanel Margin="20">
                                                <TextBlock Text="{Binding Subscription.Name}" FontWeight="Bold" FontSize="15" Height="50" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}"/>
                                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontWeight="SemiBold" Margin="0,5,0,5"/>
                                                <TextBlock Text="{Binding ExpiryDate, StringFormat='До: {0:dd.MM.yyyy}'}" FontSize="12" Opacity="0.6" Foreground="{DynamicResource TextBrush}"/>
                                                <Button Content="Отменить запись" 
                                                        Command="{Binding DataContext.CancelSubscriptionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                        CommandParameter="{Binding}" 
                                                        Margin="0,25,0,0" 
                                                        Style="{StaticResource DefaultButtonStyle}" 
                                                        Background="#FF4C4C" Foreground="White" Height="30"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{DynamicResource NoSubscriptionsMessage}" 
                                       Style="{StaticResource CustomTextBlockStyle}"
                                       Visibility="{Binding UserSubscriptions.Count, Converter={StaticResource ZeroToVisibilityConverter}}"
                                       HorizontalAlignment="Center" Margin="0,50,0,0"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>