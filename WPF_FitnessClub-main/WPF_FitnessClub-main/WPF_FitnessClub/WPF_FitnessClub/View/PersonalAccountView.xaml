<UserControl x:Class="WPF_FitnessClub.View.PersonalAccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_FitnessClub.View"
             xmlns:converters="clr-namespace:WPF_FitnessClub.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="1200">

    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="Esc" Command="{Binding CancelCommand}"/>
    </UserControl.InputBindings>

    <UserControl.Resources>
        <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converters:NonZeroToVisibilityConverter x:Key="NonZeroToVisibilityConverter"/>

        <!-- Шаблоны планов -->
        <DataTemplate x:Key="WorkoutPlanTemplate">
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                Width="380" Height="140" Margin="10" Padding="15" 
                CornerRadius="10" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" 
                               Style="{StaticResource CustomTextBlockStyle}" MaxHeight="25" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12" 
                               Opacity="0.7" Style="{StaticResource CustomTextBlockStyle}" 
                               Margin="0,5,0,0" Height="60" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Чек-бокс выполнения -->
                    <CheckBox Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right"
                          IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                          Command="{Binding DataContext.MarkWorkoutPlanCompletedCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                          CommandParameter="{Binding}"/>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="NutritionPlanTemplate">
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                Width="380" Height="140" Margin="10" Padding="15" 
                CornerRadius="10" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" 
                               Style="{StaticResource CustomTextBlockStyle}" MaxHeight="25" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12" 
                               Opacity="0.7" Style="{StaticResource CustomTextBlockStyle}" 
                               Margin="0,5,0,0" Height="60" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <CheckBox Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right"
                          IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                          Command="{Binding DataContext.MarkNutritionPlanCompletedCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                          CommandParameter="{Binding}"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <!-- ОДИН ГЛАВНЫЙ СКРОЛЛЕР НА ВСЁ ОКНО -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,0,50">

                <TextBlock Text="{DynamicResource PersonalAccountTitle}" 
                           Style="{StaticResource CustomTextBlockStyle}"
                           Margin="20,40,20,20" HorizontalAlignment="Center"/>

                <!-- TabControl теперь растянут, центрируем содержимое внутри вкладок -->
                <TabControl SelectedIndex="{Binding SelectedTabIndex}" 
                            Style="{StaticResource CustomTabControlStyle}"
                            HorizontalAlignment="Stretch">

                    <!-- Вкладка 1: Личная информация -->
                    <TabItem Header="{DynamicResource PersonalInfoTab}" Style="{StaticResource CustomTabItemStyle}">
                        <StackPanel Width="500" HorizontalAlignment="Center" Margin="0,30,0,30">

                            <!-- ФИО -->
                            <TextBlock Text="{DynamicResource FullName}" Style="{StaticResource CustomTextBlockStyle}" />
                            <TextBox Text="{Binding FullName, UpdateSourceTrigger=LostFocus}" 
                 IsEnabled="{Binding IsEditMode}" 
                 Style="{StaticResource GeneralTextBoxStyle}"
                 PreviewTextInput="FullNameTextBox_PreviewTextInput" 
                 CommandManager.PreviewExecuted="TextBox_PreviewExecuted"/>

                            <!-- ЛОГИН -->
                            <TextBlock Text="{DynamicResource Login}" Style="{StaticResource CustomTextBlockStyle}" Margin="0,15,0,0"/>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=LostFocus}" 
                 IsEnabled="{Binding IsEditMode}" 
                 Style="{StaticResource GeneralTextBoxStyle}"/>
                            
                            <!-- ТЕЛЕФОН -->
                            <TextBlock Text="{DynamicResource PhoneLabel}" Style="{StaticResource CustomTextBlockStyle}" Margin="0,15,0,0"/>
                            <TextBox Text="{Binding Phone}" IsEnabled="{Binding IsEditMode}" Style="{StaticResource GeneralTextBoxStyle}"/>

                            <!-- EMAIL -->
                            <TextBlock Text="{DynamicResource ClientPlansEmailLabel}" Style="{StaticResource CustomTextBlockStyle}" Margin="0,15,0,0"/>
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                 IsEnabled="{Binding IsEditMode}" 
                 Style="{StaticResource GeneralTextBoxStyle}"/>
                            <TextBlock Text="{Binding EmailErrorMessage}" 
                   Foreground="Red" FontSize="11" 
                   Visibility="{Binding IsEmailError, Converter={StaticResource BooleanToVisibilityConverter}}"
                   HorizontalAlignment="Left" Margin="0,2,0,0"/>

                            <!-- ПОЛ (вынесен отдельно над физическими данными) -->
                            <TextBlock Text="{DynamicResource GenderLabel}" Style="{StaticResource CustomTextBlockStyle}" Margin="0,15,0,0"/>
                            <ComboBox SelectedIndex="{Binding GenderIndex}" IsEnabled="{Binding IsEditMode}" Style="{StaticResource CustomComboBoxStyle}" Height="35">
                                <ComboBoxItem Content="{DynamicResource Male}"/>
                                <ComboBoxItem Content="{DynamicResource Female}"/>
                            </ComboBox>
                            <!-- СЕТКА: Возраст, Вес, Рост -->
                            <Grid Margin="0,15,0,0" Visibility="{Binding IsClientRole, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- ВОЗРАСТ (Строго целое) -->
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="{DynamicResource AgeLabel}" Style="{StaticResource CustomTextBlockStyle}"/>
                                    <TextBox Text="{Binding AgeText, UpdateSourceTrigger=LostFocus}" 
                 PreviewTextInput="IntegerValidationTextBox"
                 IsEnabled="{Binding IsEditMode}" 
                 Style="{StaticResource GeneralTextBoxStyle}"/>
                                </StackPanel>

                                <!-- ВЕС (Дробное, до 3 знаков) -->
                                <StackPanel Grid.Column="1" Margin="5,0,5,0">
                                    <TextBlock Text="{DynamicResource WeightLabel}" Style="{StaticResource CustomTextBlockStyle}"/>
                                    <TextBox Text="{Binding WeightText, UpdateSourceTrigger=LostFocus, StringFormat=\{0:F3\}}" 
                 PreviewTextInput="WeightValidationTextBox"
                 IsEnabled="{Binding IsEditMode}" 
                 Style="{StaticResource GeneralTextBoxStyle}"/>
                                </StackPanel>

                                <!-- РОСТ (Строго целое, как просили) -->
                                <StackPanel Grid.Column="2" Margin="5,0,0,0">
                                    <TextBlock Text="{DynamicResource HeightLabel}" Style="{StaticResource CustomTextBlockStyle}"/>
                                    <TextBox Text="{Binding HeightText, UpdateSourceTrigger=LostFocus}" 
                 PreviewTextInput="IntegerValidationTextBox"
                 IsEnabled="{Binding IsEditMode}" 
                 Style="{StaticResource GeneralTextBoxStyle}"/>
                                </StackPanel>
                            </Grid>

                            <!-- КБЖУ (только для клиентов) -->
                            <Border Visibility="{Binding IsClientRole, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="10" Margin="0,30,0,0" Padding="20" Effect="{StaticResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource DailyCaloriesLabel}" FontWeight="Bold" HorizontalAlignment="Center" Style="{StaticResource CustomTextBlockStyle}"/>
                                    <TextBlock Text="{Binding DailyCalories}" Style="{StaticResource CustomTextBlockStyle}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- КНОПКИ -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                                <Button Content="{DynamicResource EditButton}" Command="{Binding EditCommand}" Visibility="{Binding ViewModeVisible}" Style="{StaticResource DefaultButtonStyle}" Margin="0,0,10,0" Width="120"/>
                                <Button Content="{DynamicResource SaveButton}" Command="{Binding SaveCommand}" Visibility="{Binding EditModeVisible}" Style="{StaticResource DefaultButtonStyle}" Margin="0,0,10,0" Width="100"/>
                                <Button Content="{DynamicResource CancelButton}" Command="{Binding CancelCommand}" Visibility="{Binding EditModeVisible}" Style="{StaticResource DefaultButtonStyle}" Width="100"/>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <!-- Вкладка 2: Настройки -->
                    <TabItem Header="{DynamicResource AppSettingsTab}" Style="{StaticResource CustomTabItemStyle}">
                        <StackPanel Width="450" HorizontalAlignment="Center" Margin="0,30,0,30">
                            <TextBlock Text="{DynamicResource LanguageSelection}" Style="{StaticResource CustomTextBlockStyle}" HorizontalAlignment="Center"/>
                            <ComboBox x:Name="LanguageSelectionComboBox" SelectionChanged="LanguageSelectionComboBox_SelectionChanged" Style="{StaticResource CustomComboBoxStyle}" Margin="0,5,0,25">
                                <ComboBoxItem Content="{DynamicResource RussianLanguage}" Tag="ru-RU" />
                                <ComboBoxItem Content="{DynamicResource EnglishLanguage}" Tag="en-US" />
                            </ComboBox>
                            <TextBlock Text="{DynamicResource ThemeSelection}" Style="{StaticResource CustomTextBlockStyle}" HorizontalAlignment="Center"/>
                            <ComboBox x:Name="ThemeSelectionComboBox" SelectionChanged="ThemeSelectionComboBox_SelectionChanged" Style="{StaticResource CustomComboBoxStyle}">
                                <ComboBoxItem Content="{DynamicResource LightTheme}" Tag="Light" />
                                <ComboBoxItem Content="{DynamicResource DarkTheme}" Tag="Dark" />
                            </ComboBox>
                        </StackPanel>
                    </TabItem>

                    <!-- Вкладка 3: Безопасность -->
                    <TabItem Header="{DynamicResource SecurityTab}" Style="{StaticResource CustomTabItemStyle}">
                        <StackPanel Width="450" HorizontalAlignment="Center" Margin="0,30,0,30">
                            <TextBlock Text="{DynamicResource ChangePasswordTitle}" Style="{StaticResource HeaderTextBlockStyle}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                            <TextBlock Text="{DynamicResource YourCurrentPassword}"  Style="{StaticResource CustomTextBlockStyle}"/>
                            <!-- Файл: PersonalAccountView.xaml -->
                            <TextBox x:Name="SecurityCurrentPasswordInput" 
         Style="{StaticResource GeneralTextBoxStyle}" 
         Text="{Binding DisplayPassword, UpdateSourceTrigger=PropertyChanged}" 
         IsReadOnly="True" 
         Margin="0,5,0,15" 
         Background="#F0F0F0"
         Cursor="Arrow"/>

                            <TextBlock Text="{DynamicResource NewPassword}" Style="{StaticResource CustomTextBlockStyle}"/>
                            <PasswordBox x:Name="SecurityNewPasswordInput" Style="{StaticResource GeneralPasswordBoxStyle}" PreviewKeyDown="PasswordBox_PreviewKeyDown"/>

                            <TextBlock Text="{DynamicResource ConfirmPassword}" Style="{StaticResource CustomTextBlockStyle}" Margin="0,15,0,5"/>
                            <PasswordBox x:Name="SecurityConfirmPasswordInput" Style="{StaticResource GeneralPasswordBoxStyle}" PreviewKeyDown="PasswordBox_PreviewKeyDown"/>

                            <Button Content="{DynamicResource ChangePasswordButton}" Command="{Binding ChangePasswordCommand}" Style="{StaticResource DefaultButtonStyle}" Margin="0,30,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </TabItem>

                    <!-- Вкладки Планов -->
                    <TabItem Header="{DynamicResource WorkoutPlansTab}" Visibility="{Binding IsClientRole, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{StaticResource CustomTabItemStyle}">
                        <StackPanel MaxWidth="850" HorizontalAlignment="Center" Margin="0,30,0,30">
                            <TextBlock Text="{DynamicResource YourWorkoutPlans}" Style="{StaticResource HeaderTextBlockStyle}" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                            <ItemsControl ItemsSource="{Binding WorkoutPlans}" ItemTemplate="{StaticResource WorkoutPlanTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="{DynamicResource NutritionPlansTab}" Visibility="{Binding IsClientRole, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{StaticResource CustomTabItemStyle}">
                        <StackPanel MaxWidth="850" HorizontalAlignment="Center" Margin="0,30,0,30">
                            <TextBlock Text="{DynamicResource YourNutritionPlans}" Style="{StaticResource HeaderTextBlockStyle}" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                            <ItemsControl ItemsSource="{Binding NutritionPlans}" ItemTemplate="{StaticResource NutritionPlanTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </TabItem>

                    <!-- Вкладка 6: Мои занятия (АДАПТИВНАЯ И ЛИСТАЕТСЯ) -->
                    <TabItem Header="{DynamicResource MySubscriptionsTab}" Style="{StaticResource CustomTabItemStyle}" Visibility="{Binding IsClientRole, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel MaxWidth="1200" HorizontalAlignment="Center" Margin="0,30,0,30">
                            <TextBlock Text="Ваши текущие записи" Style="{StaticResource HeaderTextBlockStyle}" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                            <ItemsControl ItemsSource="{Binding UserSubscriptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="270" Height="240" Margin="10" CornerRadius="12" 
                                                Background="{DynamicResource SecondaryBackgroundBrush}" Effect="{StaticResource CardShadow}">
                                            <StackPanel Margin="20">
                                                <TextBlock Text="{Binding Subscription.Name}" FontWeight="Bold" FontSize="15" Height="50" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}"/>
                                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontWeight="SemiBold" Margin="0,5,0,5"/>
                                                <TextBlock Text="{Binding ExpiryDate, StringFormat='До: {0:dd.MM.yyyy}'}" FontSize="12" Opacity="0.6" Foreground="{DynamicResource TextBrush}"/>
                                                <Button Content="{DynamicResource CancelButton}" 
                                                        Command="{Binding DataContext.CancelSubscriptionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                        CommandParameter="{Binding}" 
                                                        Margin="0,25,0,0" 
                                                        Style="{StaticResource DefaultButtonStyle}" 
                                                        Background="{DynamicResource PrimaryRedBrush}" Foreground="White" Height="30"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{DynamicResource NoSubscriptionsMessage}" 
                                       Style="{StaticResource CustomTextBlockStyle}"
                                       Visibility="{Binding UserSubscriptions.Count, Converter={StaticResource ZeroToVisibilityConverter}}"
                                       HorizontalAlignment="Center" Margin="0,50,0,0"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>