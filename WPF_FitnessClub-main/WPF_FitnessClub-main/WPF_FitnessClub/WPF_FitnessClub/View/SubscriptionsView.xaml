<UserControl x:Class="WPF_FitnessClub.View.SubscriptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_FitnessClub.View"
             xmlns:vm="clr-namespace:WPF_FitnessClub.ViewModels"
             xmlns:models="clr-namespace:WPF_FitnessClub.Models"
             xmlns:converters="clr-namespace:WPF_FitnessClub.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:RatingToStarsConverter x:Key="RatingToStarsConverter"/>
        <DataTemplate x:Key="StarTemplate" DataType="{x:Type converters:Star}">
            <TextBlock FontSize="16" Margin="0" Padding="0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Type}" Value="{x:Static converters:StarType.Full}">
                                <Setter Property="Text" Value="★"/>
                                <Setter Property="Foreground" Value="Gold"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Type}" Value="{x:Static converters:StarType.Half}">
                                <Setter Property="Text" Value="★"/>
                                <Setter Property="Foreground" Value="Gold"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Type}" Value="{x:Static converters:StarType.Empty}">
                                <Setter Property="Text" Value="☆"/>
                                <Setter Property="Foreground" Value="Gray"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Focusable="True" MouseDown="Grid_MouseDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Панель с подписками -->
        <ScrollViewer Grid.Column="0"
                      Style="{StaticResource ResponsiveScrollViewerStyle}" 
                      VerticalScrollBarVisibility="Hidden">
            <ItemsControl ItemsSource="{Binding FilteredSubscriptions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Left" Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:Subscription}">
                        <!-- Уменьшаем ширину до 180 и маргин до 5, чтобы они стояли плотнее -->
                        <Border Width="200" 
            Height="300" 
            Background="{DynamicResource SecondaryBackgroundBrush}" 
            BorderBrush="{DynamicResource LightGrayBrush}"
            BorderThickness="1"
            CornerRadius="0" 
            Margin="8" 
            MouseDown="Subscription_MouseDown"
            Effect="{StaticResource CardShadow}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="110"/>
                                    <!-- Фиксируем высоту картинки -->
                                    <RowDefinition Height="*"/>
                                    <!-- Остальное место под текст -->
                                </Grid.RowDefinitions>

                                <!-- Картинка -->
                                <Border Grid.Row="0" CornerRadius="10,10,0,0" ClipToBounds="True">
                                    <Image Stretch="UniformToFill"
                       Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"/>
                                </Border>

                                <!-- Текст -->
                                <Grid Grid.Row="1" Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <!-- Название -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- Цена -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- Описание -->
                                        <RowDefinition Height="*"/>
                                        <!-- ПУСТОЕ МЕСТО (заберет всё свободное пространство) -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- ЗВЕЗДЫ (всегда будут внизу) -->
                                    </Grid.RowDefinitions>

                                    <!-- 1. Название -->
                                    <TextBlock Grid.Row="0" 
               Text="{Binding Name}"
               FontWeight="Bold" FontSize="13"
               MaxHeight="35" TextWrapping="Wrap"
               Foreground="{DynamicResource TextBrush}"/>

                                    <!-- 2. Цена -->
                                    <TextBlock Grid.Row="1" 
               FontSize="14" FontWeight="Bold"
               Foreground="{StaticResource PrimaryRedBrush}" 
               Margin="0,2,0,2"
               Text="{Binding Price, StringFormat={}{0:0.00} Br}"/>

                                    <!-- 3. Описание -->
                                    <TextBlock Grid.Row="2" 
               Text="{Binding Description}"
               TextWrapping="Wrap"
               FontSize="10" Foreground="#666666"
               MaxHeight="45"/>

                                    <!-- 4. Звезды (ТЕПЕРЬ СТРОГО ВНИЗУ благодаря Grid.Row="4") -->
                                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,5,0,0">
                                        <ItemsControl ItemsSource="{Binding Rating, Converter={StaticResource RatingToStarsConverter}}"
                      ItemTemplate="{StaticResource StarTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>

                                        <!-- Цифра рейтинга рядом со звездами для красоты -->
                                        <TextBlock Text="{Binding Rating, StringFormat='({0:F1})'}" 
                   FontSize="10" Margin="5,0,0,0" 
                   VerticalAlignment="Center" Opacity="0.5"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Кнопка управления панелью фильтров -->
        <Button Grid.Column="1"
                HorizontalContentAlignment="Right" 
                Content="{Binding ManipulatePanelButtonContent}" 
                VerticalAlignment="Top" 
                HorizontalAlignment="Right" 
                Command="{Binding ToggleFilterPanelCommand}" 
                Style="{StaticResource DefaultButtonStyle}" 
                Margin="10"
                Padding="10,5"/>

        <!-- Панель фильтров -->
        <Border Grid.Column="1" 
                Style="{StaticResource CustomBorderStyle}"
                MinWidth="200"
                MaxWidth="300"
                Visibility="{Binding FilterPanelVisibility}"
                Margin="0,40,0,-85">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="10*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="1" 
                           Grid.Row="1" 
                           MaxWidth="200">
                    <TextBlock Text="{DynamicResource SearchButton}" 
                             Padding="20,0,20,0" 
                             Style="{StaticResource HeaderTextBlockStyle}" />

                    <TextBox Width="190" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource CustomTextBoxStyle}" Height="30"/>

                    <TextBlock Text="{DynamicResource Price}" 
                             Padding="20,20,20,0" 
                             HorizontalAlignment="Left" 
                             VerticalAlignment="Center" 
                             Margin="0,0,0,5" 
                             Style="{StaticResource HeaderTextBlockStyle}" />

                    <Grid Margin="10,5,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <!-- Для текста "от" и "до" -->
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Цена ОТ -->
                        <TextBlock Text="{DynamicResource From}" 
               Grid.Row="0" Grid.Column="0"
               HorizontalAlignment="Left" VerticalAlignment="Center"
               Foreground="{DynamicResource TextBrush}"
               Style="{StaticResource CustomTextBlockStyle}"/>

                        <TextBox x:Name="MinCostInput"
             Grid.Row="0" Grid.Column="1" 
             Margin="5,0,0,10" 
             Text="{Binding MinCost, UpdateSourceTrigger=PropertyChanged}" 
             PreviewTextInput="PriceTextBox_PreviewTextInput"
             PreviewKeyDown="PriceTextBox_PreviewKeyDown"
             TextChanged="PriceTextBox_TextChanged"
             LostFocus="PriceTextBox_LostFocus"
             Style="{StaticResource GeneralTextBoxStyle}"/>

                        <!-- Цена ДО -->
                        <TextBlock Text="{DynamicResource To}" 
               Grid.Row="1" Grid.Column="0"
               HorizontalAlignment="Left" VerticalAlignment="Center"
               Foreground="{DynamicResource TextBrush}"
               Style="{StaticResource CustomTextBlockStyle}"/>

                        <TextBox x:Name="MaxCostInput"
             Grid.Row="1" Grid.Column="1" 
             Margin="5,0,0,10"
             Text="{Binding MaxCost, UpdateSourceTrigger=PropertyChanged}" 
             PreviewTextInput="PriceTextBox_PreviewTextInput"
             PreviewKeyDown="PriceTextBox_PreviewKeyDown"
             TextChanged="PriceTextBox_TextChanged"         
             LostFocus="PriceTextBox_LostFocus"                  
             Style="{StaticResource GeneralTextBoxStyle}"/>
                    </Grid>
                    <TextBlock Text="{DynamicResource Type}" 
                             Padding="20,20,0,0" 
                             Style="{StaticResource HeaderTextBlockStyle}"/>

                    <!-- Блок ТИП -->
                    <ComboBox SelectedValuePath="Tag" 
          SelectedValue="{Binding SelectedTypeKey, UpdateSourceTrigger=PropertyChanged}" 
          Style="{StaticResource CustomComboBoxStyle}" Height="30">
                        <ComboBoxItem Content="{DynamicResource All}" Tag="All"/>
                        <ComboBoxItem Content="{DynamicResource Unlimited}" Tag="Unlimited"/>
                        <ComboBoxItem Content="{DynamicResource Morning}" Tag="Morning"/>
                        <ComboBoxItem Content="{DynamicResource Evening}" Tag="Evening"/>
                        <ComboBoxItem Content="{DynamicResource Group}" Tag="Group"/>
                        <ComboBoxItem Content="{DynamicResource Single}" Tag="Single"/>
                    </ComboBox>

                    <TextBlock Text="{DynamicResource Duration}" 
                             Margin="20,20,0,0" 
                             Style="{StaticResource HeaderTextBlockStyle}" Height="29" />

                    <!-- Блок ДЛИТЕЛЬНОСТЬ -->
                    <ComboBox SelectedValuePath="Tag" 
          SelectedValue="{Binding SelectedDurationKey, UpdateSourceTrigger=PropertyChanged}" 
          Style="{StaticResource CustomComboBoxStyle}" Height="30">
                        <ComboBoxItem Content="{DynamicResource All}" Tag="All"/>
                        <ComboBoxItem Content="{DynamicResource Visit1}" Tag="Visit1"/>
                        <ComboBoxItem Content="{DynamicResource Visit4}" Tag="Visit4"/>
                        <ComboBoxItem Content="{DynamicResource Visit8}" Tag="Visit8"/>
                        <ComboBoxItem Content="{DynamicResource Visit16}" Tag="Visit16"/>
                        <ComboBoxItem Content="{DynamicResource Visit32}" Tag="Visit32"/>
                    </ComboBox>

                    <Button Content="Сбросить фильтры" 
        Command="{Binding ResetFiltersCommand}"
        Style="{StaticResource DefaultButtonStyle}"
        Margin="10,20,10,0"
        Height="35"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl> 