<Window x:Class="WPF_FitnessClub.View.SubscriptionDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_FitnessClub"
        xmlns:vm="clr-namespace:WPF_FitnessClub.ViewModels"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        xmlns:converters="clr-namespace:WPF_FitnessClub.Converters"
        mc:Ignorable="d"
        Title="{DynamicResource SubscriptionDetailsTitle}" 
        Height="800" Width="800"
        WindowStartupLocation="CenterScreen"
        MinWidth="600px"
        MinHeight="500px"
        Style="{StaticResource WindowStyle}">

    <Window.Resources>
        <converters:RatingToStarsConverter x:Key="RatingToStarsConverter"/>
        <DataTemplate DataType="{x:Type converters:Star}">
            <TextBlock FontSize="20" Margin="0" Padding="0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Type}" Value="{x:Static converters:StarType.Full}">
                                <Setter Property="Text" Value="★"/>
                                <Setter Property="Foreground" Value="Gold"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Type}" Value="{x:Static converters:StarType.Half}">
                                <Setter Property="Text" Value="★"/>
                                <Setter Property="Foreground" Value="Gold"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Type}" Value="{x:Static converters:StarType.Empty}">
                                <Setter Property="Text" Value="☆"/>
                                <Setter Property="Foreground" Value="Gray"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DataTemplate>
        
        <!-- Общие стили для современного дизайна -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="10" ShadowDepth="2" Direction="270" Color="#22000000" Opacity="0.3"/>
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightGrayBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>
        <Style x:Key="ModernButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Margin" Value="5,5,5,5"/>
            <Setter Property="Padding" Value="15,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="1" Direction="270" Color="#22000000" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="7" ShadowDepth="2" Direction="270" Color="#22000000" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryRedBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="ModernTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource CustomTextBlockStyle}">
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>
        <Style x:Key="ImageBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightGrayBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>
    </Window.Resources>

    
    <Border Background="{DynamicResource WindowBackgroundBrush}" Padding="15">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">
                <!-- 1. ЗАГОЛОВОК: Теперь БЕЗ ModernCardStyle, чтобы углы точно были острыми -->
                <Border Background="{DynamicResource PrimaryRedBrush}" 
        CornerRadius="10,10,0,0" 
        BorderThickness="0"
        Padding="20,10"
        Margin="0,0,0,0">
                    <!-- Убрали отступ снизу, чтобы "слить" со следующим блоком -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Название: Просмотр -->
                        <TextBlock Text="{Binding SubscrName}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"
                   Visibility="{Binding ViewModeVisible}" Foreground="White" Grid.Row="0"/>

                        <!-- Название: Редактирование (БЕЛОЕ и без лишних линий) -->
                        <TextBox Text="{Binding SubscrName, UpdateSourceTrigger=PropertyChanged}"
                 FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"
                 Visibility="{Binding EditModeVisible}" 
                 Foreground="White" Background="Transparent" 
                 BorderThickness="0,0,0,1" BorderBrush="White" CaretBrush="White"
                 Height="50" MaxLength="30" Grid.Row="0"/>

                        <!-- Рейтинг -->
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,5,0,0" Visibility="{Binding ViewModeVisible}">
                            <ItemsControl ItemsSource="{Binding Rating, Converter={StaticResource RatingToStarsConverter}}"
                          ItemTemplate="{StaticResource StarTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <TextBlock Text="{Binding Rating, StringFormat=({0:F1})}" Foreground="White" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 2. ИЗОБРАЖЕНИЕ (Углы сверху - 0, чтобы стыковалось с заголовком) -->
                <Border Style="{StaticResource ImageBorderStyle}" CornerRadius="0,0,8,8" BorderThickness="1,0,1,1" Margin="0,0,0,15">
                    <Grid>
                        <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}" Height="300" Stretch="Uniform" HorizontalAlignment="Center"/>
                        <Button Content="{DynamicResource SelectImage}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10"
                Command="{Binding ChooseImageCommand}" Visibility="{Binding EditModeVisible}" Style="{StaticResource ModernButtonStyle}"/>
                    </Grid>
                </Border>

                <!-- БЛОК ОСНОВНОЙ ИНФОРМАЦИИ -->
                <Border Style="{StaticResource ModernCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource SubscriptionInfo}" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="135"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="45"/>
                                <RowDefinition Height="45"/>
                            </Grid.RowDefinitions>

                            <!-- ЦЕНА -->
                            <TextBlock Text="{DynamicResource Price}" Grid.Row="0" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock Text="{Binding Price, StringFormat={}{0:0.00} Br}" Visibility="{Binding ViewModeVisible}"/>
                                <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding EditModeVisible}" Width="150" HorizontalAlignment="Left" Style="{StaticResource CustomTextBoxStyle}"/>
                            </StackPanel>

                            <!-- ТИП (Важно: биндинг к SubscriptionType) -->
                            <TextBlock Text="{DynamicResource Type}" Grid.Row="1" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock Text="{Binding LocalizedType}" Visibility="{Binding ViewModeVisible}"/>
                                <ComboBox Visibility="{Binding EditModeVisible}" Width="180" HorizontalAlignment="Left" Style="{StaticResource CustomComboBoxStyle}"
                          SelectedValuePath="Tag" 
                          SelectedValue="{Binding SubscriptionType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBoxItem Content="{DynamicResource Single}" Tag="Single"/>
                                    <ComboBoxItem Content="{DynamicResource Group}" Tag="Group"/>
                                    <ComboBoxItem Content="{DynamicResource Unlimited}" Tag="Unlimited"/>
                                    <ComboBoxItem Content="{DynamicResource Morning}" Tag="Morning"/>
                                    <ComboBoxItem Content="{DynamicResource Evening}" Tag="Evening"/>
                                    <ComboBoxItem Content="{DynamicResource Standard}" Tag="Standard"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- ДЛИТЕЛЬНОСТЬ (Важно: биндинг к Duration) -->
                            <TextBlock Text="{DynamicResource Duration}" Grid.Row="2" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock Text="{Binding LocalizedDuration}" Visibility="{Binding ViewModeVisible}"/>
                                <ComboBox Visibility="{Binding EditModeVisible}" Width="180" HorizontalAlignment="Left" Style="{StaticResource CustomComboBoxStyle}"
                          SelectedValuePath="Tag" 
                          SelectedValue="{Binding Duration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBoxItem Content="{DynamicResource Visit1}" Tag="Visit1"/>
                                    <ComboBoxItem Content="{DynamicResource Visit4}" Tag="Visit4"/>
                                    <ComboBoxItem Content="{DynamicResource Visit8}" Tag="Visit8"/>
                                    <ComboBoxItem Content="{DynamicResource Visit16}" Tag="Visit16"/>
                                    <ComboBoxItem Content="{DynamicResource Visit32}" Tag="Visit32"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                <!-- Описание -->
                <Border Style="{StaticResource ModernCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Description}" 
                               Style="{StaticResource SectionHeaderStyle}"/>
                            
                        <TextBlock Text="{Binding Description}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"
                               Visibility="{Binding ViewModeVisible}" 
                               Foreground="{DynamicResource TextBrush}"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             Height="100"
                             Margin="0,10,0,0"
                             AcceptsReturn="True"
                             Visibility="{Binding EditModeVisible}" 
                             Foreground="{DynamicResource TextBrush}" 
                             Style="{DynamicResource CustomTextBoxStyle}"
                             MaxLength="500"/>
                    </StackPanel>
                </Border>

                <!-- Отзывы -->
                <Border Style="{StaticResource ModernCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Reviews}" 
                               Style="{StaticResource SectionHeaderStyle}"/>

                        <Border BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,10,0,0" 
        Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{StaticResource LightGrayBrush}">
                            <Grid>
                                <!-- ТЕПЕРЬ ОТЗЫВЫ ПРИВЯЗАНЫ К КОЛЛЕКЦИИ -->
                                <ItemsControl ItemsSource="{Binding Reviews}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource LightGrayBrush}" BorderThickness="1" CornerRadius="8" 
            Padding="12" Margin="5" Background="White" Width="280" Effect="{StaticResource CardShadow}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding User}" FontWeight="Bold" Foreground="#333" Margin="0,0,0,5"/>

                                                    <!-- Твои звезды (оставляем) -->
                                                    <ItemsControl ItemsSource="{Binding Score, Converter={StaticResource RatingToStarsConverter}}"
                          ItemTemplate="{StaticResource StarTemplate}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                    </ItemsControl>

                                                    <!-- Твой комментарий (оставляем) -->
                                                    <TextBlock Text="{Binding Comment}" TextWrapping="Wrap" Margin="0,8,0,0" FontSize="12" Foreground="#555"/>

                                                    <!-- ДОБАВЛЯЕМ КНОПКУ УДАЛЕНИЯ -->
                                                    <Button Content="{DynamicResource DeleteReviewButton}"
                    Margin="0,10,0,0"
                    Background="{DynamicResource PrimaryRedBrush}" Foreground="White" FontSize="10" 
                    HorizontalAlignment="Right"
                    Style="{StaticResource ModernButtonStyle}"
                    Command="{Binding DataContext.DeleteReviewCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding Id}"
                    Visibility="{Binding DataContext.DeleteReviewVisible, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Сообщение, когда нет отзывов -->
                                <TextBlock Text="{DynamicResource NoReviews}" 
                   FontSize="16" FontStyle="Italic" HorizontalAlignment="Center" 
                   Margin="0,30" Foreground="{StaticResource MediumGrayBrush}"
                   Visibility="{Binding Reviews.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Сообщение о необходимости подписки для отзыва -->
                <Border Style="{StaticResource ModernCardStyle}" Visibility="{Binding SubscribeToReviewVisible}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource SubscribeToLeaveReview}"
                                  Foreground="{DynamicResource TextBrush}"
                                  TextAlignment="Center"
                                  FontStyle="Italic"
                                  Margin="0,10,0,10"
                                  TextWrapping="Wrap"/>
                        
                        <Button Content="{DynamicResource BookButton}"
                                Command="{Binding SubscribeCommand}"
                                Style="{StaticResource ModernButtonStyle}"
                                HorizontalAlignment="Center"
                                MinWidth="150"/>
                    </StackPanel>
                </Border>

                <!-- Написать отзыв-->
                <Border Style="{StaticResource ModernCardStyle}" Visibility="{Binding WriteReviewVisible}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource YourOpinionMatters}" 
                               Style="{StaticResource SectionHeaderStyle}"/>
                               
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Информационный блок о публикации отзыва -->
                            <TextBlock Text="{DynamicResource ReviewWillBePostedAsCurrentUser}" 
                                   Grid.Row="0"
                                   Margin="0,0,0,15"
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource TextBrush}"/>
                            
                            <TextBlock Text="{DynamicResource Rating}" 
                                   Grid.Row="1" 
                                   Margin="0,0,0,5"
                                   Foreground="{DynamicResource TextBrush}"/>
                            
                            <StackPanel x:Name="RatingRadioBox" 
                                    Grid.Row="2" 
                                    Margin="0,0,0,15"
                                    Orientation="Horizontal">
                                <RadioButton Content="1" 
                                         Checked="Radio_Checked"
                                         Style="{DynamicResource CustomRadioButtonStyle}"/>
                                <RadioButton Content="2" 
                                         Checked="Radio_Checked"
                                         Style="{DynamicResource CustomRadioButtonStyle}"/>
                                <RadioButton Content="3" 
                                         Checked="Radio_Checked"
                                         Style="{DynamicResource CustomRadioButtonStyle}"/>
                                <RadioButton Content="4" 
                                         Checked="Radio_Checked"
                                         Style="{DynamicResource CustomRadioButtonStyle}"/>
                                <RadioButton Content="5" 
                                         Checked="Radio_Checked"
                                         Style="{DynamicResource CustomRadioButtonStyle}"/>
                            </StackPanel>

                            <TextBlock Text="{DynamicResource Comment}" 
                                   Grid.Row="3" 
                                   Margin="0,0,0,5"
                                   Foreground="{DynamicResource TextBrush}"/>
                            <TextBox x:Name="CommentBox" 
                                 Grid.Row="4" 
                                 Height="80" 
                                 Margin="0,0,0,15"
                                 TextWrapping="Wrap"
                                 Text="{Binding ReviewComment, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource CustomTextBoxStyle}"
                                 MaxLength="200"/>
                        </Grid>
                            
                        <Button x:Name="AddReviewButton" 
                            Content="{DynamicResource SaveButton}" 
                            HorizontalAlignment="Right" 
                            Command="{Binding AddReviewCommand}" 
                            Style="{StaticResource ModernButtonStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Кнопки управления -->
                <Border Style="{StaticResource ModernCardStyle}" 
                    Background="{DynamicResource SecondaryBackgroundBrush}">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <Button Content="{DynamicResource EditButton}"
                            MinWidth="120"
                            Command="{Binding EditCommand}"
                            Visibility="{Binding AdminEditVisible}" 
                            Style="{StaticResource ModernButtonStyle}"/>

                        <Button Content="{DynamicResource SaveButton}"
                            MinWidth="120"
                            Command="{Binding SaveCommand}"
                            Visibility="{Binding EditModeVisible}" 
                            Style="{StaticResource ModernButtonStyle}"/>

                        <Button Content="{DynamicResource DeleteButton}"
                            MinWidth="120"
                            Command="{Binding DeleteCommand}"
                            Visibility="{Binding EditModeVisible}" 
                            Style="{StaticResource ModernButtonStyle}"/>

                        <Button Content="{DynamicResource CancelButton}"
                            MinWidth="120"
                            Command="{Binding CancelCommand}"
                            Visibility="{Binding EditModeVisible}" 
                            Style="{StaticResource ModernButtonStyle}"/>

                        <Button Content="{DynamicResource BookButton}"
                            MinWidth="120"
                            Command="{Binding SubscribeCommand}"
                            Visibility="{Binding CanSubscribeVisible}" 
                            Style="{StaticResource ModernButtonStyle}"/>

                        <Button Content="{DynamicResource CloseButton}"
                            MinWidth="120"
                            Command="{Binding CloseCommand}" 
                            Style="{StaticResource ModernButtonStyle}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
