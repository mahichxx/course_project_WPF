<Window x:Class="WPF_FitnessClub.View.ClientPlansDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_FitnessClub.View"
        xmlns:converters="clr-namespace:WPF_FitnessClub.Converters"
        mc:Ignorable="d"
        Title="{DynamicResource ClientPlansTitle}" Height="750" Width="950" 
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Style="{StaticResource WindowStyle}">

    <Window.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <!-- Стиль для текста статуса (переводной) -->
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Text" Value="{DynamicResource TaskStatusCompleted}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCompleted}" Value="False">
                    <Setter Property="Text" Value="{DynamicResource TaskStatusNotCompleted}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Шаблон карточки плана -->
        <DataTemplate x:Key="PlanItemTemplate">
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" Margin="5" Padding="15" CornerRadius="0" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,5" Opacity="0.7" Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="{Binding StartDate, StringFormat='Период: {0:dd.MM.yyyy} - '}" FontSize="12" Foreground="{DynamicResource TextBrush}">
                            <Run Text="{Binding EndDate, StringFormat='dd.MM.yyyy'}"/>
                        </TextBlock>
                    </StackPanel>
                    <Border Grid.Column="1" Background="{Binding IsCompleted, Converter={StaticResource BoolToColorConverter}}" 
                            Padding="10,5" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Style="{StaticResource StatusTextStyle}"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка с инфо о клиенте -->
        <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" Padding="20">
            <Grid>
                <StackPanel>
                    <TextBlock Text="{DynamicResource ClientPlansHeaderText}" Style="{StaticResource HeaderTextBlockStyle}" Margin="0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="{DynamicResource ClientPlansClientLabel}" Opacity="0.6"/>
                        <TextBlock Text="{Binding Client.FullName}" FontWeight="Bold" Margin="5,0" Foreground="{DynamicResource PrimaryRedBrush}"/>
                    </StackPanel>
                </StackPanel>
                <Button HorizontalAlignment="Right" Content="{DynamicResource RefreshButton}" Style="{StaticResource DefaultButtonStyle}" Width="120" Click="RefreshButton_Click"/>
            </Grid>
        </Border>

        <!-- Вкладки (теперь как в Личном кабинете) -->
        <TabControl Grid.Row="1" Margin="10" Style="{StaticResource CustomTabControlStyle}">

            <!-- ПЛАНЫ ТРЕНИРОВОК -->
            <TabItem Header="{DynamicResource WorkoutPlansTab}" Style="{StaticResource CustomTabItemStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ИСПРАВЛЕННЫЙ БЛОК КНОПОК ТРЕНИРОВОК -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10" 
                    Visibility="{Binding IsWorkoutPlanViewMode, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <!-- Команды должны быть WorkoutPlan, а не NutritionPlan! -->
                        <Button Content="{DynamicResource AddButton}" 
                    Command="{Binding AddWorkoutPlanCommand}" 
                    Style="{StaticResource DefaultButtonStyle}" Width="100"/>

                        <Button Content="{DynamicResource EditButton}" 
                    Command="{Binding EditWorkoutPlanCommand}" 
                    Style="{StaticResource DefaultButtonStyle}" Width="100"/>

                        <Button Content="{DynamicResource DeleteButton}" 
                    Command="{Binding DeleteWorkoutPlanCommand}" 
                    Style="{StaticResource DefaultButtonStyle}" Background="#FF4C4C" Width="100"/>
                    </StackPanel>

                    <!-- Список -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding WorkoutPlans}" ItemTemplate="{StaticResource PlanItemTemplate}" 
                             Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding IsWorkoutPlanViewMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                             SelectedItem="{Binding SelectedWorkoutPlan, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <!-- Режим редактирования (Линии под полями) -->
                    <Border Grid.Row="1" Visibility="{Binding IsWorkoutPlanEditMode, Converter={StaticResource BooleanToVisibilityConverter}}" Background="{DynamicResource SecondaryBackgroundBrush}" Padding="20">
                        <StackPanel MaxWidth="500">
                            <TextBlock Text="{DynamicResource Title}" Style="{StaticResource CustomTextBlockStyle}"/>
                            <TextBox Text="{Binding NewWorkoutPlanTitle, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource GeneralTextBoxStyle}"/>

                            <TextBlock Text="{DynamicResource Description}" Style="{StaticResource CustomTextBlockStyle}" Margin="0,15,0,0"/>
                            <TextBox Text="{Binding NewWorkoutPlanDescription, UpdateSourceTrigger=PropertyChanged}" Height="80" TextWrapping="Wrap" Style="{StaticResource GeneralTextBoxStyle}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Right">
                                <Button Content="{DynamicResource SaveButton}" Command="{Binding SaveWorkoutPlanCommand}" Style="{StaticResource DefaultButtonStyle}" Width="120"/>
                                <Button Content="{DynamicResource CancelButton}" Command="{Binding CancelWorkoutPlanEditCommand}" Style="{StaticResource DefaultButtonStyle}" Width="100"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ПЛАНЫ ПИТАНИЯ (Аналогично) -->
            <TabItem Header="{DynamicResource NutritionPlansTab}" Style="{StaticResource CustomTabItemStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10"
                                Visibility="{Binding IsNutritionPlanViewMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Content="{DynamicResource AddButton}" Command="{Binding AddNutritionPlanCommand}" Style="{StaticResource DefaultButtonStyle}" Width="100"/>
                        <Button Content="{DynamicResource EditButton}" Command="{Binding EditNutritionPlanCommand}" Style="{StaticResource DefaultButtonStyle}" Width="100"/>
                        <Button Content="{DynamicResource DeleteButton}" Command="{Binding DeleteNutritionPlanCommand}" Style="{StaticResource DefaultButtonStyle}" Background="#FF4C4C" Width="100"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" 
         ItemsSource="{Binding NutritionPlans}" 
         ItemTemplate="{StaticResource PlanItemTemplate}" 
         Background="Transparent" BorderThickness="0" 
         ScrollViewer.VerticalScrollBarVisibility="Auto"
         Visibility="{Binding IsNutritionPlanViewMode, Converter={StaticResource BooleanToVisibilityConverter}}"
         SelectedItem="{Binding SelectedNutritionPlan, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Border Grid.Row="1" Visibility="{Binding IsNutritionPlanEditMode, Converter={StaticResource BooleanToVisibilityConverter}}" Background="{DynamicResource SecondaryBackgroundBrush}" Padding="20">
                        <StackPanel MaxWidth="500">
                            <TextBlock Text="{DynamicResource Title}" Style="{StaticResource CustomTextBlockStyle}"/>
                            <TextBox Text="{Binding NewNutritionPlanTitle, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource GeneralTextBoxStyle}"/>
                            <TextBlock Text="{DynamicResource Description}" Style="{StaticResource CustomTextBlockStyle}" Margin="0,15,0,0"/>
                            <TextBox Text="{Binding NewNutritionPlanDescription, UpdateSourceTrigger=PropertyChanged}" Height="80" TextWrapping="Wrap" Style="{StaticResource GeneralTextBoxStyle}"/>
                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0" HorizontalAlignment="Right">
                                <Button Content="{DynamicResource SaveButton}" Command="{Binding SaveNutritionPlanCommand}" Style="{StaticResource DefaultButtonStyle}" Width="120"/>
                                <Button Content="{DynamicResource CancelButton}" Command="{Binding CancelNutritionPlanEditCommand}" Style="{StaticResource DefaultButtonStyle}" Width="100"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>